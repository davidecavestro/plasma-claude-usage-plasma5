[Desktop Entry]
Name=Claude Usage
Comment=Display Claude Code usage statistics (session and weekly limits) in your taskbar. Shows real-time usage percentages with color-coded indicators.
Icon=claude-usage-widget
Type=Service
ServiceTypes=Plasma/Applet
X-KDE-ServiceTypes=Plasma/Applet

X-Plasma-API=declarativeappletscript
X-Plasma-MainScript=ui/main.qml

X-KDE-PluginInfo-Author=izll (Plasma 5 port: Davide Cavestro)
X-KDE-PluginInfo-Name=org.kde.plasma.claudeusage.plasma5
X-KDE-PluginInfo-Version=1.3.6
X-KDE-PluginInfo-Website=https://github.com/davidecavestro/plasma-claude-usage-plasma5
X-KDE-PluginInfo-Category=System Information
X-KDE-PluginInfo-License=GPL-3.0-or-later
X-KDE-PluginInfo-EnabledByDefault=true
